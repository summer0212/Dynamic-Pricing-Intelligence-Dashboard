# ------------------------------------------------------------------------------
# Klypup Dynamic Pricing Intelligence - Environment Configuration
# ------------------------------------------------------------------------------
# Rename this file to `.env` and fill in your actual values before running the app.

# 1. Database Configuration
# We use PostgreSQL for robust relational data and ACID compliance.
# Format: postgresql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/klypup_db

# 2. Security (JWT Authentication)
# A strong secret key is required for signing JWT access tokens.
# You can generate a secure one using: `openssl rand -hex 32`
JWT_SECRET_KEY=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440 # 24 hours

# 3. AI / LLM Configuration (Groq)
# We use Groq's API for ultra-fast LPU inference of the Llama-3.1 model.
# Get a free API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
